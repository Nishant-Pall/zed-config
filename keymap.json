// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "cmd-b": "workspace::ToggleRightDock",
      "ctrl-`": "workspace::ToggleBottomDock",
      "cmd-g": "git_panel::FocusEditor",
      "ctrl-shift-g": null,
      "cmd-n": null,
      "cmd-shift-n": "workspace::NewFile"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": ["workspace::SendKeystrokes", "escape"]
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "shift-k": "editor::Hover",
      "gd": "editor::GoToDefinition",
      "cmd-j": "pane::ActivatePrevItem",
      "cmd-k": "pane::ActivateNextItem",
      "cmd-n": null
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
      "cmd-0": "pane::ActivateLastItem"
    }
  },
  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "enter": "editor::Newline",
      "cmd-p": "editor::ContextMenuPrev",
      "cmd-n": "editor::ContextMenuNext",
      "pageup": "editor::ContextMenuFirst",
      "pagedown": "editor::ContextMenuLast"
    }
  }
]
